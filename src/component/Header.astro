---
import Navigation from "./Navigation.astro"
import Social from "./Social.astro"
---

<header>
    <div class="header">
        <Navigation />
        <div class="logo">forbear</div>
        <Social />
    </div>
</header>

<style>
    header {
        /* padding: 16px; */
        border-bottom: 1px solid var(--border-clr);
    }

    .header {
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-family: var(--font-logo);
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .logo {
        font-family: var(--font-logo);
        text-transform: uppercase;
        letter-spacing: 3px;
        font-size: 1.8rem;
    }

</style>
