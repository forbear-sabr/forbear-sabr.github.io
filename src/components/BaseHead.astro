---
import '../styles/styles.css';
const {title} = Astro.props;
---

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<meta name="generator" content={Astro.generator} />

<!-- Google Icon -->
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20,400,0,0&icon_names=dashboard" />

<!-- Google tag (gtag.js) -->
<script is:inline type="text/partytown" async src="https://www.googletagmanager.com/gtag/js?id=G-J0HNPGTN0C"></script>
<script is:inline type="text/partytown">
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-J0HNPGTN0C');
</script>

<title>{title}</title>
