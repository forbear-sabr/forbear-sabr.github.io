---
import HomeLayout from "../layouts/HomeLayout.astro"
---

<HomeLayout>
	<div class="main">
		<div class="content">
			<h1>Forbear</h1>
			<div class="click">
				<a href="/home">Click Me!</a>
			</div>
		</div>
	</div>
</HomeLayout>

<style>
	.main {
		height: 100vh;
		width: 100%;
		display: flex;
		justify-content: center;
		align-items: center;
	}
	.content {
		text-align: center;

		& h1 {
			font-size: 3.5rem;
			font-family: 'Poiret One', sans-serif;
			font-weight: 400;
			letter-spacing: 2px;
			text-shadow: 4px 1px 14px rgba(54, 54, 54, 1);
		}
	}
	.click a {
		color: #CAACDE;
		font-size: 1.2em;
	}
</style>